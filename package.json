{
  "name": "side-by-side-browser",
  "version": "0.1.0",
  "description": "A two-pane browser for comparing before/after migration pages.",
  "main": "src/main.js",
  "type": "commonjs",
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "tw:build": "tailwindcss -i ./src/styles/tailwind.css -o ./src/styles/app.css --minify",
    "tw:watch": "tailwindcss -i ./src/styles/tailwind.css -o ./src/styles/app.css --watch",
    "start": "pnpm run tw:build && electron .",
    "dev": "pnpm run tw:build && electron .",
    "devtools": "pnpm run tw:build && electron . --open-devtools",
    "check": "node --check src/main.js && node --check src/settings.js && node --check src/chrome-preload.js && node --check src/remote-preload.js && node --check src/chrome.js",
    "app:dir": "pnpm run tw:build && electron-builder --dir",
    "app:dist": "pnpm run tw:build && electron-builder",
    "pack": "pnpm run tw:build && electron-builder --dir",
    "dist": "pnpm run tw:build && electron-builder"
  },
  "keywords": [
    "browser",
    "compare",
    "migration",
    "electron"
  ],
  "author": "Yotsuyanagi",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "bootstrap-icons": "^1.13.1",
    "electron": "^42.5.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.3.1"
  },
  "build": {
    "appId": "com.ytyng.side-by-side-browser",
    "productName": "Side by Side Browser",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "resources"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "icon": "resources/icon.png"
    }
  },
  "allowScripts": {
    "electron@42.5.0": true,
    "electron-winstaller@5.4.0": true
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  }
}
